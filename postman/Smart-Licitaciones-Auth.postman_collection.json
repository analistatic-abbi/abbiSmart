                  "console.log('✓ Correos únicos:', pm.environment.get('adminCorreo'));"
                ]
              }
            },
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }
          ],
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/health" }
        },
