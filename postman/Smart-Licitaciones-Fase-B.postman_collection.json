        {
          "name": "11. GET Config dias_espera_respuesta_crm",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/configuracion/dias_espera_respuesta_crm"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }]
        },
        {
          "name": "12. PATCH Config dias_espera_respuesta_crm",
          "request": {
            "method": "PATCH",
