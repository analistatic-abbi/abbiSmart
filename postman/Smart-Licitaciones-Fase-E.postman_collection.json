            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.test('array data', () => pm.expect(pm.response.json().data).to.be.an('array');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "11. PATCH Marcar todas leídas",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/notificaciones/leer-todas"
          }
        },
        {
          "name": "12. PATCH Habilitar carga masiva",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"valor\": \"true\"\n}"
            },
            "url": "{{baseUrl}}/configuracion/carga_masiva_habilitada"
          }
        },
        {
          "name": "13. POST Carga masiva proyecciones (texto content)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "content",
                  "type": "text",
                  "value": "anio_proyectado,fecha_estimada_publicacion,valor_venta,valor_facturacion\n2028,2028-03-15,1000000,900000",
                  "description": "Alternativa fiable en Postman si el adjunto file llega vacío."
                }
              ]
            },
            "url": "{{baseUrl}}/carga-masiva/proyecciones"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.test('filas procesadas', () => pm.expect(pm.response.json().filasExitosas).to.be.at.least(1);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "14. GET Logs carga masiva",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/carga-masiva/logs"
          }
        },
        {
          "name": "15. DELETE Proyección (soft)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/proyecciones/{{proyeccionId}}"
          }
        }
      ]
    },
    {
      "name": "📎 Prueba manual — subir CSV (archivo)",
      "description": "Prueba de carga masiva con **archivo .csv real**.\n\n**Antes:** ejecute pasos 1–5 y 12 del flujo automático (login + habilitar carga masiva), o use un `accessToken` válido.\n\n**Archivo de ejemplo:** `postman/proyecciones-carga-ejemplo.csv` en este repo.",
      "item": [
        {
          "name": "POST Carga masiva proyecciones — archivo CSV",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "description": "En Postman: tipo File → Select Files → elija proyecciones-carga-ejemplo.csv (NO use Text)."
                }
              ]
            },
            "url": "{{baseUrl}}/carga-masiva/proyecciones"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const file = pm.request.body?.formdata?.find((row) => row.key === 'file');",
                  "if (!file || file.type !== 'file') {",
                  "  console.warn('Configure el campo file como tipo File en Body → form-data');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('al menos 1 fila exitosa', () => pm.expect(body.filasExitosas).to.be.at.least(1));",
                  "} else if (pm.response.code === 400) {",
                  "  console.warn('Archivo vacío en Postman: abra Body → form-data → file → Select Files y elija el .csv de nuevo.');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
