    {
      "name": "📎 Manual — archivos CSV",
      "description": "Body → form-data → `file` (tipo File). Archivos en carpeta `postman/` del repo.",
      "item": [
        {
          "name": "POST Carga clientes — archivo",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file" }] },
            "url": "{{baseUrl}}/carga-masiva/clientes"
