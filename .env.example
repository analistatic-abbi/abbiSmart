# =============================================================================
# Smart Licitaciones — Backend (.env.example)
# Copie este archivo a .env y ajuste los valores para su entorno local.
# =============================================================================

# --- Aplicación ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# --- Base de datos MariaDB (licitaciones_abbi) ---
# TypeORM 0.3+ usa mysql2 como driver para type: mariadb
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=licitaciones_abbi

# --- CORS (orígenes separados por coma) ---
CORS_ORIGINS=http://localhost:4200

# --- Logging ---
LOG_LEVEL=info

# --- Seguridad ---
BCRYPT_ROUNDS=12
ACTIVATION_TOKEN_EXPIRES_HOURS=48
# Clave temporal para POST /users sin JWT (solo desarrollo/bootstrap)
ADMIN_DEV_KEY=dev-secret-change-me
MAX_LOGIN_ATTEMPTS=5
SESSION_EXPIRES_DAYS=7
PRE_AUTH_EXPIRES_MINUTES=15
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# --- JWT (obligatorio: mínimo 32 caracteres) ---
JWT_ACCESS_SECRET=cambiar-por-secreto-aleatorio-minimo-32-caracteres
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Cookie refresh token HttpOnly ---
COOKIE_REFRESH_NAME=abbi_refresh
COOKIE_REFRESH_PATH=/api/v1/auth
COOKIE_REFRESH_MAX_AGE=604800
# En producción usar true con HTTPS
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
COOKIE_DOMAIN=

# --- Mail SMTP ---
# Si MAIL_HOST está vacío, los enlaces se imprimen en logs (desarrollo)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@abbi.com
FRONTEND_URL=http://localhost:4200

# --- Swagger (documentación API en /api/docs) ---
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
SWAGGER_TITLE=Smart Licitaciones API
SWAGGER_DESCRIPTION=API backend del sistema de gestión de licitaciones ABBI
SWAGGER_VERSION=1.0
